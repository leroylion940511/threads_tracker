# --- Core ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database ---
# Use SQLite for local dev; switch to postgres URL for production.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/threads_tracker
DATABASE_URL=sqlite+aiosqlite:///./data/threads_tracker.sqlite3

# --- Apify (Threads scraper) ---
# 沒填就自動 fallback 到 FakeThreadsScraper（產生遞增假資料），demo 不需要填
APIFY_TOKEN=
# v1 legacy actor — single post / author timeline (M5 會換掉)
APIFY_ACTOR_ID=apify/threads-scraper
# v3 探索層用的關鍵字搜尋 actor（watcher.data，input = keywords array）
APIFY_SEARCH_ACTOR_ID=watcher.data/search-threads-by-keywords

# --- LLM provider ---
# 預設 anthropic；要換 minimax 改這個值（再填下面對應的 *_API_KEY）
LLM_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_OPUS_MODEL=claude-opus-4-7

# --- MiniMax (OpenAI 相容 chat completion) ---
# 國際站可改成 https://api.minimaxi.chat/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_CHAT_PATH=/text/chatcompletion_v2
MINIMAX_MODEL=abab6.5s-chat

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# --- Scheduling ---
# Polling intervals (minutes) per tier; matches proposal §4.4
POLL_HOT_MINUTES=15
POLL_WARM_MINUTES=60
POLL_COLD_MINUTES=360
ARCHIVE_AFTER_DAYS=30

# --- v3 探索層 ---
# 每 N 小時跑一次 keyword discovery；每個 keyword 最多抓 M 筆
# 依 M1 成本估算，12h × 2 ≈ $84/月；要更密可 6h × 3 ≈ $246/月
DISCOVERY_INTERVAL_HOURS=12
DISCOVERY_MAX_PER_KEYWORD=2
DISCOVERY_SORT_BY_RECENT=true

# --- Detection thresholds (proposal §4.1) ---
HOT_LIKE_THRESHOLD=1000
HOT_REPLY_THRESHOLD=200
HOT_GROWTH_RATIO=0.5
